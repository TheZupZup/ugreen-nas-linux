#!/usr/bin/env bash

set -Eeuo pipefail

readonly data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
readonly state_home="${XDG_STATE_HOME:-$HOME/.local/state}"

readonly installation_directory="$data_home/ugreen-nas-linux"
readonly wine_prefix="$installation_directory/prefix"
readonly application_executable="$installation_directory/app/UGREEN NAS.exe"

readonly log_directory="$state_home/ugreen-nas-linux"
readonly log_file="$log_directory/ugreen-nas.log"

fail() {
    printf 'Erreur : %s\n' "$1" >&2
    exit 1
}

command -v wine >/dev/null 2>&1 ||
    fail "Wine est introuvable."

[[ -f "$application_executable" ]] ||
    fail "UGREEN NAS n’est pas installé."

mkdir -p "$log_directory"

# Les applications lancées depuis un menu graphique peuvent recevoir des
# descripteurs standard fermés. Electron exige cependant des descripteurs
# stdin, stdout et stderr valides.
exec </dev/null
exec >>"$log_file"
exec 2>&1

export WINEPREFIX="$wine_prefix"
export ELECTRON_NO_ATTACH_CONSOLE=1
export WINEDEBUG=-all

exec wine "$application_executable" "$@"
